# ============================================
# AI Private Coach — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ─── Telegram Bot ───
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── Discord Bot (optional) ───
# Get from https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ─── WhatsApp (optional, via Twilio) ───
# Get from https://console.twilio.com
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# WHATSAPP_FROM_NUMBER=+14155238886
# WHATSAPP_ADMIN_NUMBERS=+85212345678,+85287654321

# ─── AI API Key ───
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: custom API base URL (e.g., for OpenCode / DeepSeek proxies)
# OPENAI_BASE_URL=https://api.opencode.ai/v1

# Optional: model name (default: gpt-4o-mini)
# OPENAI_MODEL=deepseek-v4-flash

# Anthropic (optional alternative):
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Admin Users ───
# Comma-separated Telegram chat IDs who can run /admin_* commands
# Get your chat ID from @userinfobot on Telegram
ADMIN_CHAT_IDS=123456789

# ─── Bot Mode ───
# development = test bot + test API keys
# production  = production bot + production API keys
# test        = run pytest and exit
BOT_MODE=development

# ─── Database ───
# Database path (default: data/coach.db)
# COACH_DB_PATH=data/coach.db

# ─── Knowledge Base ───
# Path to knowledge base directory (default: knowledge/)
# COACH_KNOWLEDGE_PATH=knowledge/

# ─── QC Configuration ───
# QC interval in minutes (default: 60)
# QC_INTERVAL_MINUTES=60

# Real LLM for QC tests (default: False = use mock)
# COACH_USE_REAL_LLM=False

# ─── Garmin / Strava (optional) ───
# GARMIN_CLIENT_ID=
# GARMIN_CLIENT_SECRET=
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=

# ─── Stripe (for paid tier, optional) ───
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
